    {
      "id": "0I1bgn6Dxh3EUQmcOeHBj",
      "type": "text",
      "x": 236.37300991917806,
      "y": 759.0191473173396,
      "width": 561,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
