    {
      "id": "oOCsuy0ImiXxr8hOKuO3L",
      "type": "text",
      "x": 1335.139592427814,
      "y": 855.538243870426,
      "width": 605,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Z",
      "roundness": null,
      "seed": 1192496591,
      "version": 446,
      "versionNonce": 1465346063,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783239737938,
      "link": null,
      "locked": false,
      "text": "If No of Drivers - 60 Lac\nNo of Active Drivers - 30 Lac\nAssuming Driver Location is updated every Five Seconds,\nQPS - 30,00,000 / 5 = 6,00,000 ~ 6 Lac\n\nSQL DB can handle ~2 Lac - 4 Lac QPS\n\nMatching Consistency - \n> One Request at a time for a Ride\n> One Request at a timr for a Driver",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If No of Drivers - 60 Lac\nNo of Active Drivers - 30 Lac\nAssuming Driver Location is updated every Five Seconds,\nQPS - 30,00,000 / 5 = 6,00,000 ~ 6 Lac\n\nSQL DB can handle ~2 Lac - 4 Lac QPS\n\nMatching Consistency - \n> One Request at a time for a Ride\n> One Request at a timr for a Driver",
      "autoResize": true,
      "lineHeight": 1.25
    },
