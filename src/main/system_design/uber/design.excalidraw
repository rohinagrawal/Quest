    {
      "id": "jbkgQWh9JCy4S1yBGVITd",
      "type": "text",
      "x": 1312.435964030797,
      "y": 386.10656122768864,
      "width": 1001,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b07",
      "roundness": null,
      "seed": 888198465,
      "version": 69,
      "versionNonce": 1922816193,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783239730723,
      "link": null,
      "locked": false,
      "text": "Non-Functional Requirements (Qualities of System - Challenge, System Context, Quantization)\n\n- strong consistency, matching, driver to passenger / user 1:1\n- highly available, other than matching\n- reads > writes, estimated fare, 100:30\n- low latency, ride searching, < 1 min\n- high throughput, occasional during events, 10^5+ Requests\n\nOut of Scope\n\n- GDPR compliance & Privacy\n- Alerts and Monitoring\n- CI / CD / Deployment\n- System Failures & Resilience",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-Functional Requirements (Qualities of System - Challenge, System Context, Quantization)\n\n- strong consistency, matching, driver to passenger / user 1:1\n- highly available, other than matching\n- reads > writes, estimated fare, 100:30\n- low latency, ride searching, < 1 min\n- high throughput, occasional during events, 10^5+ Requests\n\nOut of Scope\n\n- GDPR compliance & Privacy\n- Alerts and Monitoring\n- CI / CD / Deployment\n- System Failures & Resilience",
      "autoResize": true,
      "lineHeight": 1.25
    },
